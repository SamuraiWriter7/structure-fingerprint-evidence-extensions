{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/SamuraiWriter7/Structure-Fingerprint-Evidence-Extensions-v0.1/main/schemas/comparison-result-v0.1.schema.json",
  "title": "Comparison Result v0.1",
  "description": "A minimal machine-readable object for comparing two Structure Fingerprint records. It separates proof-level comparison from inference-level comparison and does not determine authorship, origin, plagiarism, infringement, royalty allocation, or legal claims.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "subjects",
    "proof_comparison",
    "inference_comparison",
    "uncertainty",
    "review",
    "policy"
  ],
  "properties": {
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "subjects": {
      "$ref": "#/$defs/subjects"
    },
    "proof_comparison": {
      "$ref": "#/$defs/proof_comparison"
    },
    "inference_comparison": {
      "$ref": "#/$defs/inference_comparison"
    },
    "uncertainty": {
      "$ref": "#/$defs/uncertainty"
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "policy": {
      "$ref": "#/$defs/policy"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "uncertainty": {
            "properties": {
              "unresolved_references": {
                "type": "array",
                "minItems": 1
              }
            },
            "required": [
              "unresolved_references"
            ]
          }
        },
        "required": [
          "uncertainty"
        ]
      },
      "then": {
        "properties": {
          "uncertainty": {
            "properties": {
              "ambiguity_level": {
                "enum": [
                  "medium",
                  "high",
                  "unresolved"
                ]
              }
            },
            "required": [
              "ambiguity_level"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "inference_comparison": {
            "properties": {
              "comparison_class": {
                "enum": [
                  "equivalent",
                  "near_equivalent",
                  "structurally_related"
                ]
              }
            },
            "required": [
              "comparison_class"
            ]
          }
        },
        "required": [
          "inference_comparison"
        ]
      },
      "then": {
        "properties": {
          "review": {
            "properties": {
              "human_review_required": {
                "const": true
              }
            },
            "required": [
              "human_review_required"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "uri": {
      "type": "string",
      "format": "uri"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "type": {
          "type": "string",
          "enum": [
            "human",
            "ai_agent",
            "software_tool",
            "hybrid_system",
            "review_panel"
          ]
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_result_id",
        "spec_version",
        "created_at",
        "producer"
      ],
      "properties": {
        "comparison_result_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "spec_version": {
          "const": "0.1.0"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "$ref": "#/$defs/producer"
        }
      }
    },
    "subject_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fingerprint_id",
        "uri",
        "role"
      ],
      "properties": {
        "fingerprint_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "uri": {
          "$ref": "#/$defs/uri"
        },
        "role": {
          "type": "string",
          "enum": [
            "source",
            "target",
            "candidate_origin",
            "candidate_derivative",
            "compared_subject",
            "unknown"
          ]
        }
      }
    },
    "subjects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "target"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/subject_ref"
        },
        "target": {
          "$ref": "#/$defs/subject_ref"
        }
      }
    },
    "field_match": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "match_type"
      ],
      "properties": {
        "field": {
          "$ref": "#/$defs/non_empty_string"
        },
        "match_type": {
          "type": "string",
          "enum": [
            "exact",
            "near_exact",
            "partial",
            "semantic",
            "structural",
            "conflicting",
            "missing"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "proof_comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_status",
        "matched_fields",
        "conflicting_fields"
      ],
      "properties": {
        "proof_status": {
          "type": "string",
          "enum": [
            "matched",
            "partially_matched",
            "conflicting",
            "insufficient_proof",
            "not_applicable"
          ]
        },
        "matched_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field_match"
          }
        },
        "conflicting_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field_match"
          }
        },
        "proof_notes": {
          "type": "string"
        }
      }
    },
    "dimension_score": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "score"
      ],
      "properties": {
        "dimension": {
          "type": "string",
          "enum": [
            "concept_graph",
            "structure_sequence",
            "discourse_pattern",
            "terminology_cluster",
            "style_pattern",
            "metadata_proximity",
            "provenance_similarity"
          ]
        },
        "score": {
          "$ref": "#/$defs/score"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "inference_comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_class",
        "overall_similarity",
        "dimension_scores"
      ],
      "properties": {
        "comparison_class": {
          "type": "string",
          "enum": [
            "equivalent",
            "near_equivalent",
            "structurally_related",
            "weakly_related",
            "unrelated",
            "conflicting",
            "inconclusive"
          ]
        },
        "overall_similarity": {
          "$ref": "#/$defs/score"
        },
        "dimension_scores": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dimension_score"
          }
        },
        "inference_notes": {
          "type": "string"
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence",
        "ambiguity_level",
        "unresolved_references"
      ],
      "properties": {
        "confidence": {
          "$ref": "#/$defs/score"
        },
        "ambiguity_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unresolved"
          ]
        },
        "unresolved_references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uncertainty_notes": {
          "type": "string"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_review_required",
        "review_reason"
      ],
      "properties": {
        "human_review_required": {
          "type": "boolean"
        },
        "review_reason": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "high_similarity",
              "near_equivalence",
              "conflicting_proof",
              "insufficient_proof",
              "unresolved_references",
              "allocation_sensitive",
              "authorship_sensitive",
              "legal_sensitive",
              "policy_required"
            ]
          }
        },
        "recommended_review_type": {
          "type": "string",
          "enum": [
            "none",
            "technical_review",
            "editorial_review",
            "provenance_review",
            "lineage_review",
            "legal_review",
            "allocation_review",
            "multi_wing_review"
          ]
        },
        "reviewer_notes": {
          "type": "string"
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_downstream_uses",
        "prohibited_downstream_uses"
      ],
      "properties": {
        "allowed_downstream_uses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "audit_input",
              "lineage_relation_input",
              "human_review_input",
              "research_input",
              "dispute_input",
              "allocation_readiness_input"
            ]
          }
        },
        "prohibited_downstream_uses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "automatic_authorship_claim",
              "automatic_origin_claim",
              "automatic_plagiarism_claim",
              "automatic_royalty_assignment",
              "automatic_legal_claim",
              "irreversible_enforcement"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "automatic_authorship_claim"
              },
              "minContains": 1
            },
            {
              "contains": {
                "const": "automatic_origin_claim"
              },
              "minContains": 1
            },
            {
              "contains": {
                "const": "automatic_plagiarism_claim"
              },
              "minContains": 1
            },
            {
              "contains": {
                "const": "automatic_royalty_assignment"
              },
              "minContains": 1
            },
            {
              "contains": {
                "const": "automatic_legal_claim"
              },
              "minContains": 1
            }
          ]
        },
        "policy_notes": {
          "type": "string"
        }
      }
    }
  }
}
