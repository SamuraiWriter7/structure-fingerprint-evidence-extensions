{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/SamuraiWriter7/Structure-Fingerprint-Evidence-Extensions-v0.1/main/schemas/lineage-relation-v0.1.schema.json",
  "title": "Lineage Relation v0.1",
  "description": "A minimal machine-readable object for expressing an evidence-backed lineage relationship between Structure Fingerprint records using Comparison Result objects as primary evidence. It does not determine authorship, origin, infringement, or royalty allocation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "subjects",
    "evidence",
    "relation",
    "reasoning",
    "uncertainty",
    "review",
    "policy"
  ],
  "properties": {
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "subjects": {
      "$ref": "#/$defs/subjects"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "relation": {
      "$ref": "#/$defs/relation"
    },
    "reasoning": {
      "$ref": "#/$defs/reasoning"
    },
    "uncertainty": {
      "$ref": "#/$defs/uncertainty"
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "policy": {
      "$ref": "#/$defs/policy"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "relation": {
            "properties": {
              "relation_type": {
                "enum": [
                  "derived_from",
                  "adapted_from",
                  "influenced_by"
                ]
              }
            },
            "required": [
              "relation_type"
            ]
          }
        },
        "required": [
          "relation"
        ]
      },
      "then": {
        "properties": {
          "relation": {
            "properties": {
              "directionality": {
                "enum": [
                  "source_to_target",
                  "target_to_source"
                ]
              }
            },
            "required": [
              "directionality"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "relation": {
            "properties": {
              "strength": {
                "const": "strong"
              }
            },
            "required": [
              "strength"
            ]
          }
        },
        "required": [
          "relation"
        ]
      },
      "then": {
        "properties": {
          "review": {
            "properties": {
              "human_review_required": {
                "const": true
              }
            },
            "required": [
              "human_review_required"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "uncertainty": {
            "properties": {
              "ambiguity_level": {
                "enum": [
                  "high",
                  "unresolved"
                ]
              }
            },
            "required": [
              "ambiguity_level"
            ]
          }
        },
        "required": [
          "uncertainty"
        ]
      },
      "then": {
        "properties": {
          "relation": {
            "properties": {
              "strength": {
                "enum": [
                  "moderate",
                  "weak",
                  "disputed",
                  "inconclusive"
                ]
              }
            },
            "required": [
              "strength"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "uri": {
      "type": "string",
      "format": "uri"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "type": {
          "type": "string",
          "enum": [
            "human",
            "ai_agent",
            "software_tool",
            "hybrid_system",
            "review_panel"
          ]
        }
      }
    },
    "source_subject_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fingerprint_id",
        "uri",
        "role"
      ],
      "properties": {
        "fingerprint_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "uri": {
          "$ref": "#/$defs/uri"
        },
        "role": {
          "type": "string",
          "enum": [
            "possible_origin",
            "earlier_candidate",
            "compared_subject",
            "common_source_candidate",
            "unknown"
          ]
        }
      }
    },
    "target_subject_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fingerprint_id",
        "uri",
        "role"
      ],
      "properties": {
        "fingerprint_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "uri": {
          "$ref": "#/$defs/uri"
        },
        "role": {
          "type": "string",
          "enum": [
            "possible_derivative",
            "later_candidate",
            "compared_subject",
            "influenced_subject",
            "unknown"
          ]
        }
      }
    },
    "additional_subject_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fingerprint_id",
        "uri"
      ],
      "properties": {
        "fingerprint_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "uri": {
          "$ref": "#/$defs/uri"
        },
        "role": {
          "type": "string",
          "enum": [
            "common_source_candidate",
            "intermediate_candidate",
            "parallel_candidate",
            "disputed_candidate",
            "unknown"
          ]
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lineage_relation_id",
        "spec_version",
        "created_at",
        "producer"
      ],
      "properties": {
        "lineage_relation_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "spec_version": {
          "const": "0.1.0"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "$ref": "#/$defs/producer"
        }
      }
    },
    "subjects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "target"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/source_subject_ref"
        },
        "target": {
          "$ref": "#/$defs/target_subject_ref"
        },
        "additional_subjects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/additional_subject_ref"
          }
        }
      }
    },
    "comparison_result_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_id",
        "uri"
      ],
      "properties": {
        "comparison_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "uri": {
          "$ref": "#/$defs/uri"
        },
        "comparison_class": {
          "type": "string",
          "enum": [
            "equivalent",
            "near_equivalent",
            "structurally_related",
            "weakly_related",
            "unrelated",
            "conflicting",
            "inconclusive"
          ]
        },
        "overall_similarity": {
          "$ref": "#/$defs/score"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_result_refs",
        "evidence_basis"
      ],
      "properties": {
        "comparison_result_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/comparison_result_ref"
          }
        },
        "evidence_basis": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "proof_overlap",
              "structural_similarity",
              "concept_graph_similarity",
              "discourse_pattern_similarity",
              "stylistic_similarity",
              "timestamp_ordering",
              "provenance_chain",
              "citation_or_reference",
              "external_attestation",
              "human_review_note",
              "insufficient_evidence"
            ]
          }
        },
        "supporting_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_type",
        "directionality",
        "strength"
      ],
      "properties": {
        "relation_type": {
          "type": "string",
          "enum": [
            "derived_from",
            "adapted_from",
            "influenced_by",
            "structurally_related",
            "near_duplicate",
            "shared_origin_possible",
            "common_ancestor_possible",
            "independent_convergence",
            "conflicting_lineage_claim",
            "insufficient_evidence",
            "unrelated"
          ]
        },
        "directionality": {
          "type": "string",
          "enum": [
            "source_to_target",
            "target_to_source",
            "bidirectional",
            "non_directional",
            "unresolved"
          ]
        },
        "strength": {
          "type": "string",
          "enum": [
            "strong",
            "moderate",
            "weak",
            "disputed",
            "inconclusive"
          ]
        },
        "relation_summary": {
          "type": "string"
        },
        "relation_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "reasoning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rationale",
        "positive_indicators",
        "limiting_factors"
      ],
      "properties": {
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        },
        "positive_indicators": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "limiting_factors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "alternative_relations": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "derived_from",
              "adapted_from",
              "influenced_by",
              "structurally_related",
              "shared_origin_possible",
              "common_ancestor_possible",
              "independent_convergence",
              "conflicting_lineage_claim",
              "insufficient_evidence",
              "unrelated"
            ]
          }
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence",
        "ambiguity_level",
        "inherited_uncertainty"
      ],
      "properties": {
        "confidence": {
          "$ref": "#/$defs/score"
        },
        "ambiguity_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unresolved"
          ]
        },
        "inherited_uncertainty": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uncertainty_notes": {
          "type": "string"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_review_required",
        "review_reason"
      ],
      "properties": {
        "human_review_required": {
          "type": "boolean"
        },
        "review_reason": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "high_similarity",
              "directional_claim",
              "disputed_origin",
              "insufficient_evidence",
              "conflicting_comparison_results",
              "allocation_sensitive",
              "authorship_sensitive",
              "legal_sensitive",
              "policy_required"
            ]
          }
        },
        "recommended_review_type": {
          "type": "string",
          "enum": [
            "none",
            "technical_review",
            "editorial_review",
            "provenance_review",
            "lineage_review",
            "legal_review",
            "allocation_review",
            "multi_wing_review"
          ]
        },
        "reviewer_notes": {
          "type": "string"
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_downstream_uses",
        "prohibited_downstream_uses"
      ],
      "properties": {
        "allowed_downstream_uses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "dispute_input",
              "audit_input",
              "allocation_readiness_input",
              "human_review_input",
              "research_input",
              "lineage_graph_input",
              "provenance_review_input"
            ]
          }
        },
        "prohibited_downstream_uses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "automatic_authorship_claim",
              "automatic_origin_claim",
              "automatic_plagiarism_claim",
              "automatic_royalty_assignment",
              "automatic_legal_claim",
              "irreversible_enforcement"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "automatic_authorship_claim"
              },
              "minContains": 1
            },
            {
              "contains": {
                "const": "automatic_origin_claim"
              },
              "minContains": 1
            },
            {
              "contains": {
                "const": "automatic_plagiarism_claim"
              },
              "minContains": 1
            },
            {
              "contains": {
                "const": "automatic_royalty_assignment"
              },
              "minContains": 1
            },
            {
              "contains": {
                "const": "automatic_legal_claim"
              },
              "minContains": 1
            }
          ]
        },
        "policy_notes": {
          "type": "string"
        }
      }
    }
  }
}
